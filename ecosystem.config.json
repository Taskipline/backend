{
    "apps": [
        {
            "name": "taskipline-backend",
            "script": "dist/index.js",
            "instances": "max",
            "exec_mode": "cluster",
            "watch": false,
            "max_memory_restart": "1G",
            "env": {
                "NODE_ENV": "production",
                "PORT": 5000
            },
            "env_development": {
                "NODE_ENV": "development",
                "PORT": 5000
            },
            "env_staging": {
                "NODE_ENV": "staging",
                "PORT": 5000
            },
            "log_date_format": "YYYY-MM-DD HH:mm Z",
            "error_file": "logs/pm2-error.log",
            "out_file": "logs/pm2-out.log",
            "log_file": "logs/pm2-combined.log",
            "time": true,
            "autorestart": true,
            "max_restarts": 10,
            "min_uptime": "10s",
            "kill_timeout": 5000
        }
    ]
}